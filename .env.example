APP_NAME="Laravel Sin BD"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Persistencia simulada EN MEMORIA.
# No se usa ninguna base de datos. El estado de las entidades se guarda con la
# fachada Cache usando el driver "file" (storage/framework/cache), de modo que
# los datos persisten entre distintas peticiones HTTP.
# ---------------------------------------------------------------------------
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

BROADCAST_DRIVER=log
FILESYSTEM_DRIVER=local
