APP_NAME="Laravel API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Base de datos: PostgreSQL (a través del ORM Eloquent).
# Ajusta estos valores según tu servidor local de PostgreSQL.
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel_api
DB_USERNAME=postgres
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_DRIVER=log
FILESYSTEM_DRIVER=local

# ---------------------------------------------------------------------------
# Integración de IA: Google Gemini (facade Http de Laravel). Opcional: sin
# esta key, los endpoints /api/ai/* responden con un error 502 explicando que
# falta configurar Gemini, pero el resto de la API funciona igual.
# Consigue una API key gratuita en https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
